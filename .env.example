# FLoRA Validator — environment variables
# Copy this file to .env and fill in your values.
#
# Full setup instructions: docs/SETUP.md

# ── Supabase PostgreSQL connection string (required) ──────────────────────────
# Get from: Supabase dashboard → Settings → Database → Connection String → URI
# Format:   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Google Gemini API key (required for LLM validation) ───────────────────────
# Get from: https://aistudio.google.com → Get API key → Create API key
# Free tier: 15 req/min, 1M tokens/day — no credit card needed
GEMINI_API_KEY=AIzaSy...

# ── GitHub personal access token (optional — only for private repos) ──────────
# Get from: GitHub → Settings → Developer settings → Fine-grained tokens
# Permissions needed: Contents: Read-only on the source repo
# Leave blank if forrtproject/flora-extractor is public
GITHUB_TOKEN=

# ── GitHub source repo for nightly CSV sync ───────────────────────────────────
# Change only if you've forked the extractor repo
GITHUB_REPO=forrtproject/flora-extractor
GITHUB_BRANCH=feature/extract
